# PBK OpenClaw MCP Server — env template
# Copy to .env or pass these via your MCP client's config block.

# Where the bridge lives. For the OptiPlex-only LAN setup use http://YOUR-LAN-IP:8788
PBK_BRIDGE_ENDPOINT=https://pbk-openclaw-bridge.onrender.com

# Bearer token. Must equal the bridge's PBK_BRIDGE_API_KEY env var (set in Render).
# Leave empty for an open local dev bridge.
PBK_BRIDGE_API_KEY=
