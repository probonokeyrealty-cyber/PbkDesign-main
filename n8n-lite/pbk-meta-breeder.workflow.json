    {
      "parameters": {
        "jsCode": "const candidates = [\n  { archetype: 'empathetic', gender: 'female', region: 'midwest', experience: 8, simulatedTranscript: 'Seller: I am nervous this is a scam but thanks for explaining it. Ava: I understand. You can verify us first. Seller: Great, sounds good, send me the details.', outcome: 'seller agreed to receive details', durationSeconds: 420, sentimentStart: 0.35, sentimentEnd: 0.78 },\n  { archetype: 'direct', gender: 'male', region: 'ohio', experience: 10, simulatedTranscript: 'Seller: What is your number? Agent: Before I give a fair number, I need to know who decides and your timeline. Seller: My wife and I decide and we need this done in weeks. Thanks for being clear.', outcome: 'qualified authority and timeline', durationSeconds: 360, sentimentStart: 0.42, sentimentEnd: 0.72 },\n  { archetype: 'analytical', gender: 'neutral', region: 'columbus', experience: 9, simulatedTranscript: 'Seller: The roof is bad and I need to know if selling as-is makes sense. Agent: Let us separate facts from pressure. Seller: That is helpful, yes, schedule a call.', outcome: 'meeting scheduled', durationSeconds: 480, sentimentStart: 0.46, sentimentEnd: 0.82 }\n];\nreturn candidates.map((candidate) => ({ json: candidate }));"
      },
      "id": "build-candidates",
      "name": "Build Candidate Matrix",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        520,
        370
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.PBK_BRIDGE_URL || 'https://pbk-openclaw-bridge.onrender.com'}}/api/persona/generate",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "X-Rex-Agent",
              "value": "true"
            },
            {
              "name": "Authorization",
              "value": "={{$env.PBK_BRIDGE_API_KEY ? 'Bearer ' + $env.PBK_BRIDGE_API_KEY : ''}}"
