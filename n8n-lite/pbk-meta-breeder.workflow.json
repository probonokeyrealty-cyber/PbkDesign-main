    {
      "parameters": {
        "jsCode": "const results = $input.all().map((item) => item.json || {});\nconst promoted = results.filter((item) => Number(item.score || 0) >= 8.5);\nreturn [{ json: {\n  checkedAt: new Date().toISOString(),\n  result: promoted.length ? 'promote_candidates_found' : 'needs_more_runs',\n  candidatesScored: results.length,\n  promoted: promoted.map((item) => ({ score: item.score, version: item.version?.id, agentName: item.version?.agentName || item.version?.persona?.name || '' }))\n} }];"
      },
