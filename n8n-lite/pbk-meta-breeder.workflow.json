      "id": "generate-persona",
      "name": "Generate Persona",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        820,
        370
      ]
    },
    {
      "parameters": {
        "jsCode": "const generated = $json || {};\nconst source = $('Build Candidate Matrix').item.json || {};\nreturn [{ json: {\n  versionId: generated.version?.id || generated.persona?.id || '',\n  agentName: generated.persona?.name || '',\n  transcript: source.simulatedTranscript || '',\n  outcome: source.outcome || '',\n  durationSeconds: source.durationSeconds || 0,\n  sentimentStart: source.sentimentStart || 0.5,\n  sentimentEnd: source.sentimentEnd || 0.5,\n  outcomeScore: /meeting|agreed|scheduled|qualified/i.test(source.outcome || '') ? 0.88 : 0.65,\n  actor: 'Meta-Agent Evaluator'\n} }];"
      },
