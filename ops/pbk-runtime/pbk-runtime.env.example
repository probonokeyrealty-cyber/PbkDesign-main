# Copy is generated automatically at .pbk-local/pbk-runtime.env by:
#   npm run infra:up
#
# Do not commit real secrets.

VOIDLLM_ADMIN_KEY=replace-with-at-least-32-chars
VOIDLLM_ENCRYPTION_KEY=replace-with-base64-32-byte-key
GOOGLE_API_KEY=replace-with-google-ai-studio-key
PBK_LLM_PROVIDER=voidllm
PBK_VOIDLLM_BASE_URL=http://127.0.0.1:8088/v1
PBK_VOIDLLM_API_KEY=replace-with-voidllm-user-api-key
PBK_VOIDLLM_MODEL=default
PBK_VOIDLLM_USER_ID=pbk-agent-planner
PBK_CODE_RUNNER_API_KEY=replace-with-at-least-32-chars
PBK_DEEPGRAM_API_KEY=replace-with-deepgram-api-key
PBK_DEEPGRAM_MODEL=nova-2
PBK_DEEPGRAM_LIVE_MODEL=nova-2-meeting
PBK_DEEPGRAM_TELNYX_ENCODING=mulaw
PBK_DEEPGRAM_TELNYX_SAMPLE_RATE=8000
PBK_DEEPGRAM_STREAM_CALLS=false
PBK_DEEPGRAM_ANALYZE_RECORDINGS=false
PBK_TELNYX_MEDIA_STREAM_TOKEN=replace-with-random-stream-token
